{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Car Detailing — Dark",
	"settings": {
		"color": {
			"palette": [
				{ "slug": "base", "color": "#0A0E17", "name": "Base" },
				{ "slug": "surface", "color": "#121A2B", "name": "Surface" },
				{ "slug": "ink", "color": "#FFFFFF", "name": "Ink" },
				{ "slug": "ink-deep", "color": "#070A11", "name": "Ink Deep" },
				{ "slug": "primary", "color": "#2E6BFF", "name": "Primary (Electric Blue)" },
				{ "slug": "primary-dark", "color": "#1E52D6", "name": "Primary Dark" },
				{ "slug": "secondary", "color": "#00D4FF", "name": "Secondary (Cyan)" },
				{ "slug": "accent", "color": "#00D4FF", "name": "Accent" },
				{ "slug": "muted", "color": "#AEB9CC", "name": "Muted" },
				{ "slug": "hairline", "color": "#1E2A42", "name": "Hairline" }
			]
		}
	},
	"styles": {
		"color": { "background": "var(--wp--preset--color--base)", "text": "#C7D0DD" },
		"elements": {
			"heading": { "color": { "text": "#FFFFFF" } },
			"button": {
				"color": { "background": "var(--wp--preset--color--primary)", "text": "#FFFFFF" }
			}
		}
	}
}
