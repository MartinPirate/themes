{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"custom": true,
			"palette": [
				{ "slug": "base", "color": "#07080B", "name": "Base (Near-black)" },
				{ "slug": "panel", "color": "#0F1117", "name": "Panel" },
				{ "slug": "panel-2", "color": "#161A24", "name": "Panel 2" },
				{ "slug": "text", "color": "#ECEDF1", "name": "Text" },
				{ "slug": "muted", "color": "#9AA0AD", "name": "Muted" },
				{ "slug": "hairline", "color": "#23262F", "name": "Hairline" },
				{ "slug": "gold", "color": "#E7C27D", "name": "Gold (Accent)" },
				{ "slug": "gold-deep", "color": "#C99B4E", "name": "Gold Deep" },
				{ "slug": "violet", "color": "#6E5CF0", "name": "Glow Violet" },
				{ "slug": "teal", "color": "#29B79E", "name": "Glow Teal" }
			],
			"gradients": [
				{ "slug": "gold-line", "name": "Gold Line", "gradient": "linear-gradient(90deg, #E7C27D 0%, #C99B4E 100%)" },
				{ "slug": "gold-soft", "name": "Gold Soft", "gradient": "linear-gradient(135deg, #F3D9A6 0%, #C99B4E 100%)" },
				{ "slug": "panel-fade", "name": "Panel Fade", "gradient": "linear-gradient(180deg, #12141C 0%, #0A0B10 100%)" }
			]
		},
		"typography": {
			"fluid": true,
			"defaultFontSizes": false,
			"customFontSize": true,
			"fontFamilies": [
				{
					"slug": "display",
					"name": "Display",
					"fontFamily": "\"Fraunces\", \"PP Editorial New\", Georgia, \"Times New Roman\", serif"
				},
				{
					"slug": "body",
					"name": "Body",
					"fontFamily": "\"Plus Jakarta Sans\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif"
				},
				{
					"slug": "mono",
					"name": "Mono",
					"fontFamily": "\"Space Mono\", ui-monospace, SFMono-Regular, Menlo, monospace"
				}
			],
			"fontSizes": [
				{ "slug": "small", "name": "Small", "size": "0.8125rem", "fluid": false },
				{ "slug": "medium", "name": "Medium", "size": "1.0625rem", "fluid": false },
				{ "slug": "large", "name": "Large", "size": "1.375rem", "fluid": { "min": "1.2rem", "max": "1.5rem" } },
				{ "slug": "x-large", "name": "X-Large", "size": "2.25rem", "fluid": { "min": "1.85rem", "max": "2.75rem" } },
				{ "slug": "xx-large", "name": "XX-Large", "size": "3.5rem", "fluid": { "min": "2.5rem", "max": "4.25rem" } },
				{ "slug": "display", "name": "Display", "size": "5rem", "fluid": { "min": "3.1rem", "max": "6rem" } }
			]
		},
		"spacing": {
			"units": ["px", "em", "rem", "vh", "vw", "%"],
			"spacingScale": { "steps": 0 },
			"spacingSizes": [
				{ "slug": "20", "name": "1", "size": "0.5rem" },
				{ "slug": "30", "name": "2", "size": "1rem" },
				{ "slug": "40", "name": "3", "size": "1.5rem" },
				{ "slug": "50", "name": "4", "size": "2.5rem" },
				{ "slug": "60", "name": "5", "size": "4rem" },
				{ "slug": "70", "name": "6", "size": "6.5rem" },
				{ "slug": "80", "name": "7", "size": "9rem" }
			]
		},
		"border": { "color": true, "radius": true, "style": true, "width": true }
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--text)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.7",
			"letterSpacing": "-0.005em"
		},
		"spacing": {
			"blockGap": "1.5rem",
			"padding": {
				"top": "0",
				"right": "var(--wp--preset--spacing--40)",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--40)"
			}
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "500",
					"lineHeight": "1.04",
					"letterSpacing": "-0.02em"
				},
				"color": { "text": "var(--wp--preset--color--text)" }
			},
			"h1": { "typography": { "fontSize": "var(--wp--preset--font-size--display)" } },
			"h2": { "typography": { "fontSize": "var(--wp--preset--font-size--xx-large)" } },
			"h3": { "typography": { "fontSize": "var(--wp--preset--font-size--x-large)" } },
			"h4": { "typography": { "fontSize": "var(--wp--preset--font-size--large)" } },
			"link": {
				"color": { "text": "var(--wp--preset--color--gold)" },
				":hover": { "color": { "text": "var(--wp--preset--color--gold-deep)" } }
			},
			"button": {
				"border": { "radius": "999px" },
				"color": {
					"background": "var(--wp--preset--color--gold)",
					"text": "#0A0B0E"
				},
				"typography": { "fontFamily": "var(--wp--preset--font-family--body)", "fontWeight": "600" },
				":hover": { "color": { "background": "var(--wp--preset--color--gold-deep)", "text": "#0A0B0E" } }
			}
		},
		"blocks": {
			"core/site-title": {
				"typography": { "fontFamily": "var(--wp--preset--font-family--display)", "fontWeight": "600", "fontSize": "1.35rem" }
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	],
	"customTemplates": [
		{ "name": "page-features", "title": "Page: Features", "postTypes": ["page"] },
		{ "name": "page-pricing", "title": "Page: Pricing", "postTypes": ["page"] },
		{ "name": "page-about", "title": "Page: About", "postTypes": ["page"] }
	]
}
